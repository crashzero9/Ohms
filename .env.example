# OHMS — environment schema (NO REAL SECRETS IN THIS FILE)
# Copy to Replit Secrets tab; do NOT commit a populated .env file.

# ---- Auth (scoped tokens, security-review C2) -----------------------------
# Generate with: openssl rand -hex 32
OHMS_API_TOKEN_READ=
OHMS_API_TOKEN_WRITE=
# Legacy single-token mode — set ONLY if scoped tokens are not set.
# OHMS_API_TOKEN=

# ---- Server ---------------------------------------------------------------
PORT=8080
# Once deployed, set to the exact hostname to enable TrustedHostMiddleware.
# Example: ohms.laura-flauraly.replit.app
OHMS_PUBLIC_HOST=

# ---- Shopify (Phase 3 wires real data) ------------------------------------
# Required Shopify scopes (H5): read_orders, write_orders, read_inventory
SHOPIFY_STORE_URL=
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2025-01

# ---- Printer (Phase 3 follow-on) -----------------------------------------
# Must be an RFC1918 private IP (validated at tool boundary).
PRINTER_IP=

# ---- Observability --------------------------------------------------------
OHMS_LOG_LEVEL=INFO

# ---- Rate limiting --------------------------------------------------------
OHMS_RATE_LIMIT_PER_MIN=60
OHMS_RATE_LIMIT_WRITE_PER_MIN=10
